{
  "name": "tanstack-start-i18next",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@tanstack/react-router": ">=1.0.0",
    "@tanstack/react-start": ">=1.0.0",
    "i18next": ">=23.0.0",
    "react": ">=18.0.0",
    "react-i18next": ">=13.0.0"
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.168.19",
    "@tanstack/react-start": "^1.167.34",
    "@types/react": "^19.0.0",
    "i18next": "^26.0.0",
    "react": "^19.0.0",
    "react-i18next": "^17.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
